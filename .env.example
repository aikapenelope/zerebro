# =============================================================================
# Zerebro - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# --- LLM Providers ---
# Builder agent (high-reasoning model for creating agents)
OPENAI_API_KEY=sk-...

# Worker agents (fast, cheap inference via Groq)
GROQ_API_KEY=gsk_...

# --- Database ---
POSTGRES_USER=zerebro
POSTGRES_PASSWORD=zerebro_dev
POSTGRES_DB=zerebro
DATABASE_URL=postgresql+asyncpg://zerebro:zerebro_dev@postgres:5432/zerebro

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Phoenix Observability ---
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces
PHOENIX_PORT=6006

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=info

# --- Model Defaults ---
# Model used for the builder agent (creates other agents)
BUILDER_MODEL=openai:gpt-4o
# Model used for worker agents (executes tasks)
WORKER_MODEL=groq:qwen/qwen3-32b
# Fallback model if worker model fails
WORKER_FALLBACK_MODEL=groq:llama-3.3-70b-versatile
