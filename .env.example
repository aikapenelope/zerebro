# =============================================================================
# Zerebro - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.

# --- LLM Providers ---
# Builder agent (high-reasoning model for creating agents)
OPENAI_API_KEY=sk-...

# Worker agents (fast, cheap inference via Groq)
GROQ_API_KEY=gsk_...

# --- Database ---
POSTGRES_USER=zerebro
POSTGRES_PASSWORD=zerebro_dev
POSTGRES_DB=zerebro
# Async URL for SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://zerebro:zerebro_dev@postgres:5432/zerebro
# Sync URL for Alembic migrations and LangGraph checkpointer (psycopg3 driver)
DATABASE_URL_SYNC=postgresql+psycopg://zerebro:zerebro_dev@postgres:5432/zerebro

# --- Phoenix Observability ---
PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006/v1/traces
PHOENIX_PORT=6006

# --- Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=info

# --- MCP Servers ---
# JSON array of MCP server configurations. Each object needs:
#   name, transport (stdio|streamable_http|sse), and transport-specific fields.
# Examples:
# MCP_SERVERS_JSON='[
#   {"name": "mcp-github", "transport": "stdio",
#    "command": "npx", "args": ["-y", "@modelcontextprotocol/server-github"],
#    "env": {"GITHUB_PERSONAL_ACCESS_TOKEN": "ghp_..."},
#    "description": "GitHub MCP server"},
#   {"name": "mcp-web", "transport": "streamable_http",
#    "url": "http://localhost:3001/mcp",
#    "description": "Web search MCP server"}
# ]'
MCP_SERVERS_JSON=

# --- Model Defaults ---
# Builder: high-reasoning model for creating agents via structured output.
# gpt-4.1 has superior instruction following + structured output vs gpt-4o.
BUILDER_MODEL=openai:gpt-4.1

# Worker: primary model for executing agent tasks.
# llama-3.3-70b-versatile is a Production model on Groq (stable, 280 tps).
WORKER_MODEL=groq:llama-3.3-70b-versatile

# Fallback: used when the primary worker model fails.
# qwen3-32b is fast (400 tps) but Preview on Groq (may be deprecated).
WORKER_FALLBACK_MODEL=groq:qwen/qwen3-32b
